{
  "name": "vibewebsite",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-01",
  "routes": [
    {
      "pattern": "vibed.nyuu.dev",
      "zone_name": "nyuu.dev",
      "custom_domain": true
    }
  ],
  "vars": {
    // Default model — override via wrangler.jsonc or dashboard
    "OPENROUTER_MODEL": "openai/gpt-oss-20b"
  }
  // Set the API key as a secret (never in config):
  //   npx wrangler secret put OPENROUTER_API_KEY
}
